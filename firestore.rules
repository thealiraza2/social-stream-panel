rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      // Users can create their own profile on signup
      allow create: if isOwner(userId);
      // Users can update their own profile (limited fields), admins can update any
      allow update: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status']));
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ==========================================
    // ORDERS COLLECTION
    // ==========================================
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Owner can only update provider response fields on their own order
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'providerOrderId']) &&
        request.resource.data.status in ['pending', 'processing', 'failed']
      );
      allow delete: if isAdmin();
    }

    // ==========================================
    // TRANSACTIONS COLLECTION
    // ==========================================
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // TICKETS COLLECTION
    // ==========================================
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ==========================================
    // SERVICES COLLECTION (public read, admin write)
    // ==========================================
    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ==========================================
    // CATEGORIES COLLECTION (public read, admin write)
    // ==========================================
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ==========================================
    // PROVIDERS COLLECTION (admin only)
    // ==========================================
    match /providers/{providerId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // SETTINGS COLLECTION (public read, admin write)
    // ==========================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // BLOG CATEGORIES (public read, admin write)
    // ==========================================
    match /blog_categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // BLOG POSTS (public read, admin write)
    // ==========================================
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // NEWS (public read, admin write)
    // ==========================================
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // FAQs (public read, admin write)
    // ==========================================
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // SUBSCRIBERS (public create, admin read/delete)
    // ==========================================
    match /subscribers/{subId} {
      allow read: if isAdmin();
      allow create: if true;
      allow delete: if isAdmin();
    }

    // ==========================================
    // BLACKLISTS (admin only)
    // ==========================================
    match /blacklist_ips/{docId} {
      allow read, write: if isAdmin();
    }
    match /blacklist_links/{docId} {
      allow read, write: if isAdmin();
    }
    match /blacklist_emails/{docId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // STAFF (admin only)
    // ==========================================
    match /staff/{staffId} {
      allow read, write: if isAdmin();
    }
    match /staff_activity/{actId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // USER ACTIVITY (admin read, auto-created)
    // ==========================================
    match /user_activity/{actId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // ==========================================
    // SYSTEM LOGS (admin only)
    // ==========================================
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // ==========================================
    // CHILD PANELS (admin only)
    // ==========================================
    match /child_panels/{panelId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // MODULES (admin only)
    // ==========================================
    match /modules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ==========================================
    // LANGUAGES (admin write, public read)
    // ==========================================
    match /languages/{langId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // PAYMENT BONUSES (admin write, user read)
    // ==========================================
    match /payment_bonuses/{bonusId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ==========================================
    // DRIP FEED (user read own, admin all)
    // ==========================================
    match /drip_feed/{feedId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ==========================================
    // SUBSCRIPTIONS (user read own, admin all)
    // ==========================================
    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ==========================================
    // INFLUENCERS COLLECTION
    // ==========================================
    match /influencers/{infId} {
      // Users can read their own influencer doc, admins read all
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Allow reading by promoCode/slug queries (for validation)
      allow list: if isSignedIn();
      // Users can create their own application
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Admins can update anything; signed-in users can only increment clicks/signups
      allow update: if isAdmin() || (isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalClicks', 'totalSignups']));
      allow delete: if isAdmin();
    }

    // ==========================================
    // REFERRAL TRACKING
    // ==========================================
    match /referral_tracking/{trackId} {
      // Influencers can read their own referral data, admins read all
      allow read: if isSignedIn();
      // System creates these on signup/deposit approval
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ==========================================
    // INFLUENCER PAYOUTS
    // ==========================================
    match /influencer_payouts/{payoutId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // MARKETING ASSETS (public read for logged users, admin write)
    // ==========================================
    match /marketing_assets/{assetId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ==========================================
    // PAYMENT METHODS (user read, admin write)
    // ==========================================
    match /paymentMethods/{methodId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
